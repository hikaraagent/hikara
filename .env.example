# hakiri reads only public chain data. nothing here is required to demo.
# fill what you have. unset keys silently downgrade the affected enrichers.

# ---- rpc ----
# any solana rpc. helius / quicknode / triton / shyft all work.
# triton and helius offer the higher rate limits hakiri needs at scale.
HAKIRI_RPC_HTTP_URL=https://api.mainnet-beta.solana.com
HAKIRI_RPC_WS_URL=wss://api.mainnet-beta.solana.com

# ---- streaming ingest (optional, recommended for production) ----
# yellowstone-grpc geyser endpoint. low-latency account + tx feed.
HAKIRI_GEYSER_GRPC_URL=
# jito-shredstream-proxy endpoint. sub-leader-level latency.
HAKIRI_SHREDSTREAM_URL=

# ---- jito block engine (public, no key) ----
HAKIRI_JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf

# ---- slot trace mode ----
# 'getblock'    — getBlock with full tx data. canonical, slow.
# 'geyser'      — yellowstone-grpc subscription.
# 'shredstream' — jito shredstream proxy. lowest latency.
HAKIRI_TRACE_MODE=getblock

# ---- ai scoring (optional) ----
# with no key set, the rule-based scorer runs alone.
ANTHROPIC_API_KEY=
HAKIRI_AI_MODEL=claude-haiku-4-5-20251001

# ---- output ----
# stdout | jsonl | webhook | all
HAKIRI_SINK=stdout
HAKIRI_JSONL_PATH=./out/hakiri.jsonl
HAKIRI_WEBHOOK_URL=

# ---- runtime ----
# how many slots behind head to start. 0 = head only. 50 = last 50 slots.
HAKIRI_BACKFILL_SLOTS=0
HAKIRI_LOG_LEVEL=info
