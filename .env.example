# hakiri reads only public chain data. nothing here is required to demo.
# fill what you have. unset keys silently downgrade the affected enrichers.

# ---- rpc / mempool ----
# any websocket-capable provider. alchemy is convenient because it exposes
# alchemy_pendingtransactions filter. infura, quicknode, ankr also work.
HAKIRI_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
HAKIRI_HTTP_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# ---- builder / relay feeds (optional, used by enrich.builder) ----
# flashbots relay is public, no key needed.
HAKIRI_RELAY_URLS=https://relay.flashbots.net,https://relay.ultrasoundmoney.org

# ---- block trace mode ----
# 'debug' uses debug_traceblockbynumber (geth/erigon).
# 'parity' uses trace_block (parity-style, openethereum).
# 'rpc' uses eth_getlogs only (no internal txs, less coverage).
HAKIRI_TRACE_MODE=rpc

# ---- ai scoring (optional) ----
# with no key set, the rule-based scorer runs alone.
ANTHROPIC_API_KEY=
HAKIRI_AI_MODEL=claude-haiku-4-5-20251001

# ---- output ----
# stdout | jsonl | webhook | all
HAKIRI_SINK=stdout
HAKIRI_JSONL_PATH=./out/hakiri.jsonl
HAKIRI_WEBHOOK_URL=

# ---- runtime ----
# how many blocks behind head to start. 0 = head only. 50 = last 50 blocks.
HAKIRI_BACKFILL_BLOCKS=0
HAKIRI_LOG_LEVEL=info
